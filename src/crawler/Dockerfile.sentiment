FROM python:3.11-slim

WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir \
    fastapi "uvicorn[standard]" transformers torch pydantic requests python-dotenv

COPY sentiment_service.py .

EXPOSE 8001
CMD ["uvicorn", "sentiment_service:app", "--host", "0.0.0.0", "--port", "8001", "--workers", "1"]
